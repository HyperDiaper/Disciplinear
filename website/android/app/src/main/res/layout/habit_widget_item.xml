<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_item_bg"
    android:padding="10dp"
    android:gravity="center_vertical">

    <!-- Emoji Container -->
    <TextView
        android:id="@+id/widget_item_emoji"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="✨"
        android:textSize="18sp" />

    <!-- Name and Progress -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp">

        <TextView
            android:id="@+id/widget_item_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Habit Name"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_item_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30m/60m"
            android:textColor="#a1a1aa"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Completed Checkmark/Dot -->
    <ImageView
        android:id="@+id/widget_item_status"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/widget_checkbox_unchecked"
        android:layout_marginEnd="4dp" />

</LinearLayout>
